# === Origins ===
NEXT_PUBLIC_APP_ORIGIN=https://app.example.com
NEXT_PUBLIC_API_ORIGIN=https://api.example.com

# === Stripe (UIは公開鍵だけ) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# === GitHub OAuth (認可URL生成に使用) ===
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# ※UIにはSecretを入れない。Server ActionsでSecretが不要なようにAPI側へ委譲。

