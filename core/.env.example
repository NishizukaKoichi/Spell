# === Database ===
DATABASE_URL=mysql://user:pass@host/db?sslaccept=strict

# === NATS (直TCP推奨) ===
NATS_URL=tls://nats.example.internal:4222
NATS_AUTH_TOKEN=
# または NKEY/JWT 認証（.creds ファイルを使用）
NATS_CREDS_FILE=core/runner.creds

# === R2 (S3互換で直接PUT/GET) ===
R2_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=spell-artifacts

# === Observability (optional) ===
OTLP_ENDPOINT=
OTLP_HEADERS=authorization=Bearer <token>

# === Logging ===
RUST_LOG=info,actix_web=info
