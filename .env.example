# ========================
# Database (Postgres 16+)
# ========================
DATABASE_URL=postgres://user:password@localhost:5432/spell_platform
DATABASE_POOL_MAX_SIZE=20

# ========================
# Storage (Tigris S3-compatible)
# ========================
TIGRIS_ACCESS_KEY=
TIGRIS_SECRET_KEY=
TIGRIS_BUCKET=spell-artifacts
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev

# ========================
# Stripe
# ========================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-10-28
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ========================
# GitHub App / OAuth
# ========================
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_CLIENT_ID=Iv1.abc...
GITHUB_APP_CLIENT_SECRET=

# ========================
# JWT & Security
# ========================
JWT_SECRET=  # openssl rand -hex 32
AUDIT_SALT_SECRET=  # openssl rand -hex 32
RECOVERY_CODE_PEPPER=  # openssl rand -hex 32

# ========================
# WebAuthn
# ========================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Spell Platform
WEBAUTHN_RP_ORIGIN=http://localhost:3000

# ========================
# Server
# ========================
BIND_ADDR=0.0.0.0:8080

# ========================
# Observability
# ========================
RUST_LOG=info,spell_platform=debug

# ========================
# Next.js (Frontend)
# ========================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WEBAUTHN_RP_ID=localhost