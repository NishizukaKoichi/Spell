# ========================
# Stripe
# ========================
STRIPE_SECRET=sk_xxx                   # Stripe Dashboard → API keys で発行
STRIPE_WEBHOOK_SECRET=whsec_xxx        # Webhookエンドポイント作成後に取得
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_xxx

# ========================
# Cloudflare R2
# ========================
R2_ACCESS_KEY=...
R2_SECRET_KEY=...
R2_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=spell-artifacts

# ========================
# GitHub App / OAuth
# ========================
GITHUB_APP_ID=...
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=...
GITHUB_OAUTH_CLIENT_ID=Iv1_...
GITHUB_OAUTH_CLIENT_SECRET=...
NEXT_PUBLIC_GITHUB_CLIENT_ID=$GITHUB_OAUTH_CLIENT_ID

# ========================
# Database (PlanetScale)
# ========================
DATABASE_URL=mysql://USER:PASSWORD@HOST/DB?sslaccept=strict

# ========================
# NATS
# ========================
NATS_URL=tls://nats.example.internal:4222
NATS_AUTH_TOKEN=...
# または NATS_CREDS_FILE を指定（NKEY/JWT認証）
NATS_CREDS_FILE=core/runner.creds

# ========================
# Core / Runner
# ========================
SESSION_SECRET=...       # openssl rand -hex 32
ADMIN_SECRET=...         # 同上、内部管理用

# ========================
# Observability (任意)
# ========================
OTLP_HEADERS="authorization=Bearer ..."

# ========================
# 補足（非シークレット）
# ========================
JWT_ISSUER=https://koichinishizuka.com
JWT_AUDIENCE=https://koichinishizuka.com
CORS_ALLOW_ORIGIN=https://koichinishizuka.com
