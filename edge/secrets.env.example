# Only the sensitive keys used by Workers (to load via scripts/wrangler-secrets.sh)

# === Security / Session ===
SESSION_SECRET=

# === GitHub (App + OAuth) ===
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === Stripe ===
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# === Database ===
DATABASE_URL=mysql://user:pass@host/db?sslaccept=strict

# === NATS (optional) ===
NATS_AUTH_TOKEN=

# === Observability (optional) ===
OTLP_HEADERS=authorization=Bearer <token>

# Note:
# - Keep non-secrets (e.g., JWT_ISSUER, R2_BUCKET) in wrangler.toml [vars]
# - If you store PEM here, keep it escaped with \n as shown.
