# === Security / Session ===
SESSION_SECRET=
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=app
CORS_ALLOW_ORIGIN=https://koichinishizuka.com

# === GitHub (App + OAuth) ===
GITHUB_APP_ID=
# PEMをそのままSecretに入れる場合は wrangler secret 推奨。envに置くなら \n で改行をエスケープ
GITHUB_APP_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# === Stripe ===
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# === Database (PlanetScale) ===
DATABASE_URL=mysql://user:pass@host/db?sslaccept=strict

# === NATS (HTTP Gateway推奨 on Edge) ===
NATS_GATEWAY=https://natsgw.internal/publish
NATS_AUTH_TOKEN=

# === R2 (Workersバインディング前提 / 署名URLのベース) ===
R2_BUCKET=spell-artifacts
R2_PUBLIC_BASE_URL=https://dl.koichinishizuka.com

# === Observability (optional) ===
OTLP_ENDPOINT=
OTLP_HEADERS=authorization=Bearer <token>

# === Ops convenience ===
DEFAULT_TENANT_ID=1
CAP_KV_PREFIX=cap
AUDIT_R2_PREFIX=audit
ARTIFACT_TTL_DAYS=7
